# Base URL of the Next.js API. Inlined at build time (EXPO_PUBLIC_* prefix
# required by Expo — see https://docs.expo.dev/guides/environment-variables/).
#
# - iOS simulator / Expo web: http://localhost:3000
# - Android emulator: http://10.0.2.2:3000 (already the default if unset)
# - Physical device: http://<your-machine-LAN-IP>:3000
EXPO_PUBLIC_API_BASE_URL="http://localhost:3000"
