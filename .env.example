# ---------------------------------------------------------------------------
# Supabase Postgres (Project Settings -> Database -> Connection string)
# DATABASE_URL: pooled connection (port 6543, pgbouncer) - used at runtime.
# DIRECT_URL:   direct connection (port 5432) - used by `prisma migrate`.
# ---------------------------------------------------------------------------
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@[PROJECT-REF].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@[PROJECT-REF].pooler.supabase.com:5432/postgres"

# ---------------------------------------------------------------------------
# Supabase Storage (Project Settings -> API)
# Service role key is server-only, never expose to the client/browser.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="[YOUR-ANON-KEY]"
SUPABASE_SERVICE_ROLE_KEY="[YOUR-SERVICE-ROLE-KEY]"

SUPABASE_STORAGE_BUCKET_SELFIES="attendance-selfies"
SUPABASE_STORAGE_BUCKET_EVIDENCE="evidence-files"

# ---------------------------------------------------------------------------
# Auth.js (NextAuth v5)
# Generate AUTH_SECRET with: npx auth secret
# ---------------------------------------------------------------------------
AUTH_SECRET="[RANDOM-SECRET]"
AUTH_GOOGLE_ID="[GOOGLE-OAUTH-CLIENT-ID]"
AUTH_GOOGLE_SECRET="[GOOGLE-OAUTH-CLIENT-SECRET]"

# Only accounts with this email domain may sign in.
ALLOWED_EMAIL_DOMAIN="srru.ac.th"

# ---------------------------------------------------------------------------
# QR check-in token signing (rotates every 15s, HMAC-signed, server verified)
# ---------------------------------------------------------------------------
QR_TOKEN_SECRET="[RANDOM-SECRET]"

# ---------------------------------------------------------------------------
# Vercel Cron -> /api/cron/close-ended-activities
# Cron request must send header: Authorization: Bearer <CRON_SECRET>
# ---------------------------------------------------------------------------
CRON_SECRET="[RANDOM-SECRET]"

# App base URL, used for absolute links in emails/notifications.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ---------------------------------------------------------------------------
# Resend (email notifications) — optional. Without RESEND_API_KEY, email
# sends are a no-op (logged only) so the app works without it in dev.
# Sign up free at resend.com, verify a sending domain, create an API key.
# ---------------------------------------------------------------------------
RESEND_API_KEY=""
RESEND_FROM_EMAIL="SRRU Check <onboarding@resend.dev>"
